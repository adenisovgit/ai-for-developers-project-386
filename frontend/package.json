{
  "name": "call-booking-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run mock\" \"vite\"",
    "dev:client": "vite",
    "mock": "prism mock ../api/openapi.yaml --port 3001",
    "build": "vue-tsc --noEmit && vite build",
    "generate-api": "openapi-generator-cli generate -i ../api/openapi.yaml -g typescript-axios -o src/api --additional-properties=supportsES6=true,typescriptThreePlus=true,withSeparateModelsAndApi=true,modelPackage=models,apiPackage=apis",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.90.2",
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.12.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-vue-next": "^0.542.0",
    "reka-ui": "^2.6.0",
    "tailwind-merge": "^3.3.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.31",
    "vue-router": "^4.6.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.25.0",
    "@stoplight/prism-cli": "^5.14.2",
    "@tanstack/vue-query-devtools": "^5.91.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
